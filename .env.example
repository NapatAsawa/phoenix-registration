# Copy to `.env` and adjust. Real `.env` is git-ignored.

NODE_ENV=development

# Postgres connection string, shared by the write model and pg-boss.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/phoenix

# API HTTP port.
API_PORT=3000

# Base URL that verification links are built from.
PUBLIC_BASE_URL=http://localhost:3000

# How long an unconfirmed registration lives before the hourly Sweep expires it
# and frees its email. Duration form (ms|s|m|h|d); defaults to 72h if unset.
PENDING_TTL=72h

# pino log level for both entrypoints (trace|debug|info|warn|error|fatal).
# Defaults to info.
LOG_LEVEL=info

# Outbound-email transport the worker uses. `console` (default) prints the
# Confirmation Email to stdout so the flow runs with no mail server; `smtp`
# delivers to SMTP_URL (Mailpit in the docker compose demo).
EMAIL_TRANSPORT=console

# SMTP endpoint used when EMAIL_TRANSPORT=smtp. Points at Mailpit.
SMTP_URL=smtp://localhost:1025

# --- Reserved for later issues (declared here so config is discoverable) ---
# TOKEN_TTL=24h
# RESEND_MIN_INTERVAL=60s
# RESEND_MAX=5
