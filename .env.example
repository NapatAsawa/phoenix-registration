# Copy to `.env` and adjust. Real `.env` is git-ignored.

NODE_ENV=development

# Postgres connection string, shared by the write model and pg-boss.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/phoenix

# API HTTP port.
API_PORT=3000

# Base URL that verification links are built from.
PUBLIC_BASE_URL=http://localhost:3000

# --- Reserved for later issues (declared here so config is discoverable) ---
